# -----------------------------------------------------------------------------
# Frontend environment (Vite exposes only VITE_* variables to the browser)
# Copy this file to `.env.local` and fill in your Supabase project values.
# -----------------------------------------------------------------------------

# Your Supabase project URL, e.g. https://xxxxxxxx.supabase.co
VITE_SUPABASE_URL=

# Your Supabase publishable/anon key (safe to expose to the browser; RLS protects data)
VITE_SUPABASE_ANON_KEY=

# Optional: application display name
VITE_APP_NAME=Speaking Assessment Platform
